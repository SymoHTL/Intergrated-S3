{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "IntegratedS3": {
    "ServiceName": "Integrated S3 MVC/Razor Sample",
    "RoutePrefix": "/integrated-s3",
    "Disk": {
      "ProviderName": "local-disk",
      "RootPath": "App_Data/IntegratedS3",
      "CreateRootDirectory": true
    }
  },
  "AllowedHosts": "*"
}
