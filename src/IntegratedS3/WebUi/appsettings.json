{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "IntegratedS3": {
    "ServiceName": "Integrated S3 Sample Host",
    "RoutePrefix": "/integrated-s3",
    "EnableAwsSignatureV4Authentication": false,
    "SignatureAuthenticationRegion": "us-east-1",
    "SignatureAuthenticationService": "s3",
    "AccessKeyCredentials": [],
    "PresignAccessKeyId": null,
    "PresignPublicBaseUrl": null,
    "ReferenceHost": {
      "StorageProvider": "Disk",
      "RoutePolicies": {
        "Route": "",
        "Root": "",
        "Compatibility": "",
        "Service": "",
        "Bucket": "",
        "Object": "",
        "Multipart": "",
        "Admin": ""
      }
    },
    "Disk": {
      "ProviderName": "local-disk",
      "RootPath": "App_Data/IntegratedS3",
      "CreateRootDirectory": true
    },
    "S3": {
      "ProviderName": "s3-primary",
      "Region": "us-east-1",
      "ServiceUrl": "",
      "ForcePathStyle": false,
      "AccessKey": "",
      "SecretKey": ""
    }
  },
  "AllowedHosts": "*"
}
