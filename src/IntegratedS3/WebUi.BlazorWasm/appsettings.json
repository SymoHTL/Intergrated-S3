{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "IntegratedS3": {
    "ServiceName": "Integrated S3 Blazor WebAssembly Sample",
    "RoutePrefix": "/integrated-s3",
    "EnableAwsSignatureV4Authentication": true,
    "PresignAccessKeyId": "browser-sample-access",
    "AccessKeyCredentials": [
      {
        "AccessKeyId": "browser-sample-access",
        "SecretAccessKey": "browser-sample-secret",
        "DisplayName": "browser-sample-user",
        "Scopes": [ "storage.read", "storage.write" ]
      }
    ],
    "Disk": {
      "ProviderName": "local-disk",
      "RootPath": "App_Data/IntegratedS3",
      "CreateRootDirectory": true
    }
  },
  "AllowedHosts": "*"
}
